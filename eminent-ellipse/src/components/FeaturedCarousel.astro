---
import type { CollectionEntry } from "astro:content";
import { getProfileImage } from "../lib/figures";

interface Props {
  figures: CollectionEntry<"figures">[];
}

const { figures } = Astro.props;
---

<div class="featured-carousel">
  {figures.map((figure) => (
    <a
      href={`/${figure.id}`}
      class="featured-card"
    >
      <div class="featured-image">
        <img
          src={getProfileImage(figure).src}
          alt={getProfileImage(figure).alt}
          loading="lazy"
        />
      </div>

      <div class="featured-info">
        <strong>{figure.data.name}</strong>

        {
          figure.data.lifespan && (
            <span>{figure.data.lifespan}</span>
          )
        }
      </div>
    </a>
  ))}
</div>

<style>
  .homepage-section {
    margin-bottom: 6rem;
  }

  .section-heading {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .featured-carousel {
    display: flex;
    gap: 1.25rem;
    overflow-x: auto;
    padding-bottom: 1rem;
    scroll-snap-type: x mandatory;
    scrollbar-width: thin;
  }

  .featured-card {
    flex: 0 0 220px;
    scroll-snap-align: start;
    color: inherit;
  }

  .featured-image {
    overflow: hidden;
    background: var(--color-placeholder);
    aspect-ratio: 3 / 4;
  }

  .featured-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .featured-card:hover img {
    transform: scale(1.05);
  }

  .featured-info {
    padding-top: 0.75rem;
  }

  .featured-info strong {
    display: block;
    margin-bottom: 0.35rem;
  }

  .featured-info span {
    color: var(--color-text-alt);
    font-size: 0.85rem;
  }

  @media (max-width: 768px) {
    .featured-card {
      flex: 0 0 150px;
    }

    .section-heading {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }
</style>
