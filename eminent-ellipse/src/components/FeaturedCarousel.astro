---
import type { CollectionEntry } from "astro:content";
import { getProfileImage } from "../lib/figures";

interface Props {
  figures: CollectionEntry<"figures">[];
}

const { figures } = Astro.props;
---

<div
  class="featured-carousel"
  id="featured-carousel"
>
  {figures.map((figure, index) => (
    <a
      href={`/${figure.id}`}
      class={`featured-card ${index === 0 ? "active" : ""}`}
      data-index={index}
    >
      <div class="featured-image">
        <img
          src={getProfileImage(figure).src}
          alt={getProfileImage(figure).alt}
          loading="lazy"
        />
      </div>

      <div class="featured-info">
        <strong>{figure.data.name}</strong>

        {
          figure.data.lifespan && (
            <span>{figure.data.lifespan}</span>
          )
        }
      </div>
    </a>
  ))}
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const carousel =
      document.getElementById("featured-carousel");

    if (!carousel) return;

    const cards = Array.from(
      carousel.querySelectorAll(".featured-card")
    );

    if (!cards.length) return;

    let current =
      Math.floor(Math.random() * cards.length);

    let userInteracting = false;
    let carouselVisible = true;

    function activateCard(index) {
      cards.forEach((card) =>
        card.classList.remove("active")
      );

      const activeCard = cards[index];

      if (!activeCard) return;

      activeCard.classList.add("active");

      const carouselRect = carousel.getBoundingClientRect();
      const cardRect = activeCard.getBoundingClientRect();
      const targetLeft =
        carousel.scrollLeft +
        cardRect.left -
        carouselRect.left -
        (carousel.clientWidth - activeCard.clientWidth) / 2;

      carousel.scrollTo({
        left: targetLeft,
        behavior: "smooth",
      });
    }

    function nextCard() {
      if (userInteracting || !carouselVisible) return;

      current = (current + 1) % cards.length;

      activateCard(current);
    }

    activateCard(current);

    const interval = setInterval(nextCard, 4000);

    const observer = new IntersectionObserver(
      ([entry]) => {
        carouselVisible = entry.isIntersecting;
      },
      { threshold: 0.2 }
    );

    observer.observe(carousel);

    carousel.addEventListener("pointerdown", () => {
      userInteracting = true;
    });

    carousel.addEventListener("pointerup", () => {
      setTimeout(() => {
        userInteracting = false;
      }, 3000);
    });

    carousel.addEventListener("touchstart", () => {
      userInteracting = true;
    });

    carousel.addEventListener("touchend", () => {
      setTimeout(() => {
        userInteracting = false;
      }, 3000);
    });
  });
</script>

<style>
  .homepage-section {
    margin-bottom: 6rem;
  }

  .section-heading {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .featured-carousel {
  display: flex;

  gap: 1.5rem;

  overflow-x: auto;
  overflow-y: hidden;

  padding: 3rem 3rem 4rem;

  scroll-behavior: smooth;

  scroll-snap-type: x mandatory;

  scrollbar-width: none;

  -ms-overflow-style: none;
}

.featured-carousel::-webkit-scrollbar {
  display: none;
}

.featured-carousel {
  overflow-y: hidden;
  touch-action: pan-x;
}

  .featured-card {
    position: relative;

    flex: 0 0 220px;

    scroll-snap-align: center;

    color: inherit;

    opacity: 0.6;

    transform: scale(0.88);

    transition:
      transform 0.5s ease,
      opacity 0.5s ease;

    z-index: 1;
  }

  .featured-card.active {
    opacity: 1;

    transform: scale(1.22);

    z-index: 20;
  }

  .featured-card.active::before {
  opacity: 0.25;

  transform: scale(1.1);

}

  .featured-card.active::after {

    position: absolute;

    top: -14px;
    left: 50%;

    transform: translateX(-50%);

    padding: 0.3rem 0.8rem;

    border-radius: 999px;

    background:
      linear-gradient(
        90deg,
        var(--color-pink),
        var(--color-magenta)
      );

    color: white;

    font-size: 0.7rem;

    font-weight: 700;

    letter-spacing: 0.08em;

    box-shadow:
      0 4px 12px rgba(255, 47, 146, 0.25);
  }

  .featured-image {
    overflow: hidden;

    background: var(--color-placeholder);

    aspect-ratio: 3 / 4;

    border-radius: 18px;

    border: 1px solid rgba(255, 255, 255, 0.2);

    transition:
      border-color 0.4s ease,
      box-shadow 0.4s ease;
  }

  .featured-card.active .featured-image {
  box-shadow:
    0 0 0 1px rgba(255, 47, 146, 0.10),
    0 8px 20px rgba(255, 47, 146, 0.16);
}

  .featured-image img {
    width: 100%;
    height: 100%;

    object-fit: cover;

    transition: transform 0.4s ease;
  }

  .featured-card.active img {
    transform: scale(1.03);
  }

  .featured-card:hover img {
    transform: scale(1.05);
  }

  .featured-info {
    padding-top: 0.9rem;

    text-align: center;
  }

  .featured-info strong {
    display: block;

    margin-bottom: 0.35rem;

    transition:
      color 0.4s ease,
      transform 0.4s ease,
      font-size 0.4s ease;
  }

  .featured-card.active .featured-info strong {
    color: var(--color-white);

    font-size: 1.15rem;
  }

  .featured-info span {
    color: var(--color-text-alt);

    font-size: 0.85rem;

    transition: color 0.4s ease;
  }

  .featured-card.active .featured-info span {
    color: var(--color-text);
  }

  @media (max-width: 768px) {
    .featured-carousel {
      padding: 2rem 1rem 3rem;
    }

    .featured-card {
      flex: 0 0 150px;
    }

    .featured-card.active {
      transform: scale(1.08);
    }

    .featured-card::before {
      inset: -12px;
    }

    .section-heading {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }
  .featured-card {
  will-change: transform;
}

.featured-card::before {
  will-change: opacity, transform;
}
</style>
