---
import { siteConfig } from "../site.config";
---

<footer class="site-footer">
  <div class="footer-right">
      <div class="footer-credit">
        <span>Historical Babes Archive</span>

        {siteConfig.siteMakers.map((maker, index) => (
          <a
            href={maker.linkedInUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
          >
            {index === 0 ? "Site by " : "With "}
            {maker.name}
          </a>
        ))}
      </div>
    </div>

  <div>
    <img
      src="/images/historical-babes.gif"
      alt="Historical Babes"
      class="footer-gif"
    />
  </div>

  <div class="footer-right">
      <div>
        © 2026 {siteConfig.creator.name}
      </div>
      <a
        href={siteConfig.archive.instagramUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Historical Babes Archive Instagram"
        class="social-link"
      >
        <svg
          viewBox="0 0 24 24"
          aria-hidden="true"
          class="social-icon"
        >
          <rect
            x="3"
            y="3"
            width="18"
            height="18"
            rx="5"
            ry="5"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          />
          <circle
            cx="12"
            cy="12"
            r="4"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          />
          <circle
            cx="17.5"
            cy="6.5"
            r="1.2"
            fill="currentColor"
          />
        </svg>
      </a>

      <a
        href={siteConfig.creator.instagramUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`${siteConfig.creator.name} Instagram`}
        class="social-link"
      >
        Amelia IG
      </a>

      <a
        href={siteConfig.creator.linkedInUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="social-link"
      >
        <svg
          viewBox="0 0 24 24"
          aria-hidden="true"
          class="social-icon"
        >
          <path
            fill="currentColor"
            d="M4.98 3.5A2.48 2.48 0 1 0 5 8.46 2.48 2.48 0 0 0 4.98 3.5zM3 9h4v12H3zm7 0h3.8v1.7h.05c.53-1 1.84-2.05 3.8-2.05 4.06 0 4.8 2.67 4.8 6.14V21h-4v-5.5c0-1.31-.02-3-1.82-3-1.83 0-2.11 1.43-2.11 2.9V21h-4z"
          />
        </svg>
      </a>
    </div>
</footer>

<style>
.site-footer {
  margin-top: 8rem;

  padding: 2rem 0;

  border-top: 1px solid var(--border-color);

  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
}
</style>
