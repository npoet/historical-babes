---
import { siteConfig } from "../../site.config";
---

<section class="homepage-section creator-section">
  <div>
    <h3>Follow The Archive</h3>
    <p>
      Follow the archive for new historical finds, behind-the-scenes research, and profile updates.
    </p>
  </div>

  <div class="cta-links">
    <a href={siteConfig.archive.instagramUrl} target="_blank" rel="noopener noreferrer">Archive Instagram</a>
    <a href={siteConfig.creator.instagramUrl} target="_blank" rel="noopener noreferrer">Amelia Instagram</a>
    <a href={siteConfig.creator.linkedInUrl} target="_blank" rel="noopener noreferrer">LinkedIn</a>
    {siteConfig.newsletterUrl && (
      <a href={siteConfig.newsletterUrl} target="_blank" rel="noopener noreferrer">Newsletter</a>
    )}
    {siteConfig.supportUrl && (
      <a href={siteConfig.supportUrl} target="_blank" rel="noopener noreferrer">Support</a>
    )}
  </div>
</section>

<style>
  .creator-section {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    align-items: center;
    padding: 2rem 0;
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
  }

  .creator-section p {
    max-width: 620px;
    margin: 0;
    line-height: 1.6;
    color: var(--color-text-alt);
  }

  @media (max-width: 768px) {
    .creator-section {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
