---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import FeaturedCarousel from "../components/FeaturedCarousel.astro";
import SectionHeading from "../components/SectionHeading.astro";
import AboutArchive from "../components/home/AboutArchive.astro";
import CreatorFollow from "../components/home/CreatorFollow.astro";
import HomeHero from "../components/home/HomeHero.astro";
import HomeStats from "../components/home/HomeStats.astro";
import { siteConfig } from "../site.config";

const figures = await getCollection("figures");

const featuredIds = [
  "mar-a-orosa",
  "ada-lovelace",
  "elena-zelayeta",
  "bessie-coleman",
  "mary-therese-klinker",
  "go-won-go-mohawk",
  "adelina-otero-warren",
  "maria-stewart",
];

const featuredFigures = figures.filter((figure) =>
  featuredIds.includes(figure.id)
);

const statLinks = [
  {
    href: "/all",
    number: figures.length,
    label: "Figures",
  },
  {
    href: "/map",
    number: 5,
    label: "Continents",
  },
  {
    href: "/timeline",
    number: "2000+",
    label: "Years of History",
  },
];
---

<BaseLayout
  title={siteConfig.title}
  description={siteConfig.description}
  canonicalPath="/"
>
  <SiteHeader />

  <HomeHero />

  <section class="homepage-section">
    <SectionHeading title="Featured Babes" linkHref="/all" linkLabel="View all →">
      Featured <span class="hero-accent">Babes</span>
    </SectionHeading>

    <FeaturedCarousel figures={featuredFigures} />
  </section>

  <AboutArchive />
  <HomeStats stats={statLinks} />
  <AboutArchive compact />
  <CreatorFollow />

  <SiteFooter />
</BaseLayout>
