---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { siteConfig } from "../site.config";
import {
  formatYear,
  getOccupations,
  getStartYear,
  getStatusLabel,
  reliabilityCopy,
} from "../lib/figures";

const figures = await getCollection("figures");
const workTitle = (work: string | { title: string }) =>
  typeof work === "string" ? work : work.title;
const workYear = (work: string | { year?: number; startYear?: number }) =>
  typeof work === "string" ? undefined : work.year ?? work.startYear;
const workEndYear = (work: string | { year?: number; startYear?: number; endYear?: number }) =>
  typeof work === "string" ? undefined : work.endYear ?? work.year ?? work.startYear;
const workNote = (work: string | { note?: string }) =>
  typeof work === "string" ? "" : work.note ?? "";
const workStatus = (work: string | { status?: "reviewed" | "approximate" | "needs-source" }) =>
  typeof work === "string" ? undefined : work.status;
const seedYear = (seed: { year?: number; startYear?: number }) => seed.year ?? seed.startYear;
const seedEndYear = (seed: { year?: number; startYear?: number; endYear?: number }) =>
  seed.endYear ?? seed.year ?? seed.startYear;
const figureRows = figures.map((figure) => {
  const startYear = getStartYear(figure);
  const endYear = typeof figure.data.deathYear === "number" ? figure.data.deathYear : startYear;

  return {
    id: figure.id,
    name: figure.data.name,
    startYear,
    endYear,
    label: figure.data.lifespan ?? formatYear(startYear),
    era: figure.data.era ?? "Unknown era",
    themes: figure.data.themes ?? [],
    occupations: getOccupations(figure),
    status: getStatusLabel(figure.data.dateStatus),
    summary: figure.data.summary ?? "",
    type: "life",
    href: `/${figure.id}`,
  };
});
const workRows = figures.flatMap((figure) =>
  figure.data.importantWorks
    ?.filter((work) => typeof workYear(work) === "number")
    .map((work) => ({
      id: `${figure.id}-${workTitle(work)}`,
      figureId: figure.id,
      name: workTitle(work),
      figureName: figure.data.name,
      startYear: workYear(work),
      endYear: workEndYear(work),
      label: [workYear(work), workEndYear(work)]
        .filter((year, index, years) => typeof year === "number" && years.indexOf(year) === index)
        .map((year) => formatYear(year))
        .join("-") || "Unknown date",
      era: figure.data.era ?? "Unknown era",
      themes: figure.data.themes ?? [],
      occupations: getOccupations(figure),
      status: getStatusLabel(workStatus(work) ?? figure.data.sourceCoverageStatus),
      summary: workNote(work),
      type: "work",
      href: `/${figure.id}`,
    })) ?? []
);
const placeRows = figures.flatMap((figure) =>
  figure.data.places
    ?.filter((place) => typeof place.startYear === "number" || typeof place.endYear === "number")
    .map((place) => ({
      id: `${figure.id}-${place.name}-${place.startYear ?? place.endYear}`,
      figureId: figure.id,
      name: place.name,
      figureName: figure.data.name,
      startYear: place.startYear ?? place.endYear,
      endYear: place.endYear ?? place.startYear,
      label: [place.startYear, place.endYear]
        .filter((year, index, years) => typeof year === "number" && years.indexOf(year) === index)
        .map((year) => formatYear(year))
        .join("-") || "Unknown date",
      era: figure.data.era ?? "Unknown era",
      themes: figure.data.themes ?? [],
      occupations: getOccupations(figure),
      status: getStatusLabel(place.status),
      summary: place.note ?? "",
      type: "place",
      href: `/${figure.id}`,
    })) ?? []
);
const eventRows = figures.flatMap((figure) =>
  figure.data.contextEvents?.map((event) => ({
    id: `${figure.id}-${event.label}`,
    figureId: figure.id,
    name: event.label,
    figureName: figure.data.name,
    startYear: event.year ?? event.startYear,
    endYear: event.endYear ?? event.year ?? event.startYear,
    label: [event.year ?? event.startYear, event.endYear].filter((year) => typeof year === "number").map((year) => formatYear(year)).join("-") || "Unknown date",
    era: figure.data.era ?? "Unknown era",
    themes: figure.data.themes ?? [],
    occupations: getOccupations(figure),
    status: getStatusLabel(event.status),
    summary: event.note ?? "",
    type: "event",
    href: `/${figure.id}`,
  })) ?? []
);
const seedRows = figures.flatMap((figure) =>
  figure.data.storySeeds
    ?.filter((seed) => typeof seedYear(seed) === "number")
    .map((seed) => ({
      id: `${figure.id}-story-${seed.title}`,
      figureId: figure.id,
      name: seed.title,
      figureName: figure.data.name,
      startYear: seedYear(seed),
      endYear: seedEndYear(seed),
      label: [seedYear(seed), seedEndYear(seed)]
        .filter((year, index, years) => typeof year === "number" && years.indexOf(year) === index)
        .map((year) => formatYear(year))
        .join("-") || "Unknown date",
      era: figure.data.era ?? "Unknown era",
      themes: figure.data.themes ?? [],
      occupations: getOccupations(figure),
      status: getStatusLabel(seed.status),
      summary: seed.prompt,
      note: seed.note ?? "",
      type: "story",
      href: `/${figure.id}`,
      source: seed.source,
    })) ?? []
);
const rows = [...figureRows, ...workRows, ...placeRows, ...eventRows, ...seedRows].sort((a, b) => {
  const aYear = typeof a.startYear === "number" ? a.startYear : Number.POSITIVE_INFINITY;
  const bYear = typeof b.startYear === "number" ? b.startYear : Number.POSITIVE_INFINITY;
  return aYear - bYear;
});
const datedRows = rows.filter((row) => typeof row.startYear === "number");
const minYear = Math.min(...datedRows.map((row) => row.startYear ?? 0));
const maxYear = Math.max(new Date().getFullYear(), ...datedRows.map((row) => row.endYear ?? row.startYear ?? 0));
const range = Math.max(1, maxYear - minYear);
const eras = [...new Set(figureRows.map((row) => row.era))].sort();
const themes = [...new Set(figureRows.flatMap((row) => row.themes))].sort();
const yearBuckets = new Map<number, number>();
for (const row of datedRows) {
  const bucket = Math.floor((row.startYear ?? 0) / 50) * 50;
  yearBuckets.set(bucket, (yearBuckets.get(bucket) ?? 0) + 1);
}
const denseYear = [...yearBuckets.entries()].sort((a, b) => b[1] - a[1])[0]?.[0] ?? minYear;
const importantYear = datedRows.find((row) => row.type === "event")?.startYear ?? denseYear;
const positionFor = (year?: number) =>
  typeof year === "number" ? `${(((year - minYear) / range) * 100).toFixed(2)}%` : "0%";
const timelineMidpoint = Math.round((minYear + maxYear) / 2);
---

<BaseLayout title="Archive Timeline" description={`Explore the ${siteConfig.title} by year.`} canonicalPath="/timeline">
  <SiteHeader />

  <section class="archive-hero">
    <div>
      <span class="beta-label">Archive beta</span>
      <h2>Timeline</h2>
      <p>Lifespans, works, moves, and context events arranged across the archive.</p>
      <p class="reliability-note">{reliabilityCopy}</p>
    </div>
  </section>

  <section class="search-section timeline-controls">
    <div class="filter-grid" aria-label="Timeline filters">
      <label>
        Era
        <select id="timeline-era">
          <option value="">Any era</option>
          {eras.map((era) => <option value={era}>{era}</option>)}
        </select>
      </label>

      <label>
        Theme
        <select id="timeline-theme">
          <option value="">Any theme</option>
          {themes.map((theme) => <option value={theme}>{theme}</option>)}
        </select>
      </label>

      <label>
        Search
        <input id="timeline-search" type="search" placeholder="Try science, London, resistance..." autocomplete="off" />
      </label>

      <label>
        Type
        <select id="timeline-type">
          <option value="">All timeline notes</option>
          <option value="life">Lifespans</option>
          <option value="work">Important works</option>
          <option value="place">Place moves</option>
          <option value="event">Context events</option>
          <option value="story">Historical threads</option>
        </select>
      </label>
    </div>

    <div class="collection-chips" aria-label="Start somewhere">
      <span>Start somewhere</span>
      <button type="button" data-jump-year={denseYear}>Dense years</button>
      <button type="button" data-jump-year={importantYear}>Important years</button>
      <button type="button" data-theme-query="Science and Innovation">Scientists</button>
      <button type="button" data-theme-query="Power and Resistance">Resistance</button>
    </div>
  </section>

  {seedRows.length > 0 && (
    <section class="story-seeds" aria-labelledby="story-seeds-heading">
      <div class="section-heading">
        <div>
          <span class="beta-label">Curated threads</span>
          <h3 id="story-seeds-heading">Historical threads ready for timeline browsing</h3>
        </div>
        <span>{seedRows.length} sourced prompts</span>
      </div>

      <ol class="story-seed-list">
        {seedRows.map((seed) => (
          <li>
            <a href={seed.href}>
              <strong>{seed.name}</strong>
              <span>{seed.figureName} · {seed.label}</span>
            </a>
            <p>{seed.summary}</p>
            {seed.note && <small>{seed.note}</small>}
            <div class="story-seed-meta">
              <span class="status-pill">{seed.status}</span>
              <a href={seed.source}>Source</a>
            </div>
          </li>
        ))}
      </ol>
    </section>
  )}

  <section class="timeline-board">
    <aside class="timeline-detail" id="timeline-detail" aria-live="polite" tabindex="-1">
      <span class="beta-label">Timeline focus</span>
      <h3>Select a life, work, place, event, or thread</h3>
      <p class="muted">Use search, filters, or the quick chips to narrow the timeline, then select a marker to see sources and who was alive nearby.</p>
    </aside>

  <section class="timeline-scale" style={`--min-year: ${minYear}; --max-year: ${maxYear};`}>
    <div class="timeline-axis">
      <span>{formatYear(minYear)}</span>
      <span>{formatYear(timelineMidpoint)}</span>
      <span>{formatYear(maxYear)}</span>
    </div>

    <div class="timeline-type-key" aria-label="Timeline marker key">
      <span class="life">Lives</span>
      <span class="work">Works</span>
      <span class="place">Places</span>
      <span class="event">Events</span>
      <span class="story">Threads</span>
    </div>

    <ol class="timeline-rows">
      {rows.map((row) => (
        <li
          id={row.type === "life" ? row.id : undefined}
          class={`timeline-row ${row.type}`}
          data-era={row.era}
          data-themes={row.themes.join("|")}
          data-type={row.type}
          data-year={row.startYear ?? ""}
          data-end-year={row.endYear ?? row.startYear ?? ""}
          data-name={row.name}
          data-figure={"figureName" in row ? row.figureName : row.name}
          data-label={row.label}
          data-status={row.status}
          data-summary={row.summary}
          data-href={row.href}
          data-source={row.type === "story" && "source" in row ? row.source : ""}
          data-search={`${row.name} ${"figureName" in row ? row.figureName : ""} ${row.label} ${row.summary} ${row.era} ${row.themes.join(" ")} ${row.occupations.join(" ")} ${row.type}`}
          style={`--start: ${positionFor(row.startYear)}; --end: ${positionFor(row.endYear)};`}
        >
          <button type="button" class="timeline-bar">
            <strong>{row.name}</strong>
            {"figureName" in row && <span>{row.figureName}</span>}
          </button>
          <div class="timeline-meta">
            <span>{row.label}</span>
            <span class="status-pill">{row.status}</span>
          </div>
        </li>
      ))}
    </ol>
  </section>
  </section>

  <SiteFooter />
</BaseLayout>

<script>
  const eraFilter = document.getElementById("timeline-era") as HTMLSelectElement | null;
  const themeFilter = document.getElementById("timeline-theme") as HTMLSelectElement | null;
  const typeFilter = document.getElementById("timeline-type") as HTMLSelectElement | null;
  const timelineSearch = document.getElementById("timeline-search") as HTMLInputElement | null;
  const detail = document.getElementById("timeline-detail");
  const rows = document.querySelectorAll<HTMLElement>(".timeline-row");
  const jumpButtons = document.querySelectorAll<HTMLButtonElement>("[data-jump-year]");
  const themeButtons = document.querySelectorAll<HTMLButtonElement>("[data-theme-query]");

  const applyFilters = () => {
    const era = eraFilter?.value ?? "";
    const theme = themeFilter?.value ?? "";
    const type = typeFilter?.value ?? "";
    const query = timelineSearch?.value.toLowerCase().trim() ?? "";

    rows.forEach((row) => {
      const themes = row.dataset.themes?.split("|") ?? [];
      const searchText = row.dataset.search?.toLowerCase() ?? "";
      const matches =
        (!era || row.dataset.era === era) &&
        (!theme || themes.includes(theme)) &&
        (!type || row.dataset.type === type) &&
        (!query || searchText.includes(query));

      row.classList.toggle("hidden", !matches);
    });
  };

  [eraFilter, themeFilter, typeFilter].forEach((control) => {
    control?.addEventListener("change", applyFilters);
  });
  timelineSearch?.addEventListener("input", applyFilters);

  const renderDetail = (row: HTMLElement) => {
    if (!detail) return;
    const year = Number(row.dataset.year ?? "");
    const alive = [...rows]
      .filter((candidate) => candidate.dataset.type === "life")
      .filter((candidate) => {
        const start = Number(candidate.dataset.year ?? "");
        const end = Number(candidate.dataset.endYear ?? candidate.dataset.year ?? "");
        return Number.isFinite(year) && Number.isFinite(start) && Number.isFinite(end) && start <= year && end >= year;
      })
      .map((candidate) => candidate.dataset.name)
      .filter(Boolean)
      .slice(0, 8);

    const source = row.dataset.source
      ? `<a href="${row.dataset.source}">Open source</a>`
      : "";

    detail.innerHTML = `
      <span class="beta-label">${row.dataset.type === "story" ? "Historical thread" : row.dataset.type}</span>
      <h3>${row.dataset.name}</h3>
      <p><strong>${row.dataset.figure}</strong> · ${row.dataset.label}</p>
      <p>${row.dataset.summary || "No note yet."}</p>
      <span class="status-pill">${row.dataset.status}</span>
      <div class="timeline-detail-links">
        <a href="${row.dataset.href}">Open profile</a>
        ${source}
      </div>
      ${
        alive.length
          ? `<div class="timeline-alive"><strong>Alive around ${row.dataset.label}</strong><span>${alive.join(", ")}</span></div>`
          : ""
      }
    `;
    rows.forEach((candidate) => candidate.classList.toggle("selected", candidate === row));
    detail.focus();
  };

  rows.forEach((row) => {
    row.querySelector(".timeline-bar")?.addEventListener("click", () => renderDetail(row));
  });

  jumpButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const targetYear = Number(button.dataset.jumpYear ?? "");
      const target = [...rows].find((row) => Number(row.dataset.year) >= targetYear);
      target?.scrollIntoView({ behavior: "smooth", block: "center" });
    });
  });

  themeButtons.forEach((button) => {
    button.addEventListener("click", () => {
      if (!themeFilter) return;
      themeFilter.value = button.dataset.themeQuery ?? "";
      applyFilters();
    });
  });
</script>
