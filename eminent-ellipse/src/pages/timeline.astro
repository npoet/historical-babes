---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { siteConfig } from "../site.config";
import {
  contextLayerLabels,
  formatYear,
  getContextLayer,
  getOccupations,
  getStartYear,
  getStatusLabel,
  reliabilityCopy,
} from "../lib/figures";

const figures = await getCollection("figures");
const workTitle = (work: string | { title: string }) =>
  typeof work === "string" ? work : work.title;
const workYear = (work: string | { year?: number; startYear?: number }) =>
  typeof work === "string" ? undefined : work.year ?? work.startYear;
const workEndYear = (work: string | { year?: number; startYear?: number; endYear?: number }) =>
  typeof work === "string" ? undefined : work.endYear ?? work.year ?? work.startYear;
const workNote = (work: string | { note?: string }) =>
  typeof work === "string" ? "" : work.note ?? "";
const workStatus = (work: string | { status?: "reviewed" | "approximate" | "needs-source" }) =>
  typeof work === "string" ? undefined : work.status;
const seedYear = (seed: { year?: number; startYear?: number }) => seed.year ?? seed.startYear;
const seedEndYear = (seed: { year?: number; startYear?: number; endYear?: number }) =>
  seed.endYear ?? seed.year ?? seed.startYear;
const figureRows = figures.map((figure) => {
  const startYear = getStartYear(figure);
  const endYear = typeof figure.data.deathYear === "number" ? figure.data.deathYear : startYear;

  return {
    id: figure.id,
    name: figure.data.name,
    startYear,
    endYear,
    label: figure.data.lifespan ?? formatYear(startYear),
    era: figure.data.era ?? "Unknown era",
    themes: figure.data.themes ?? [],
    occupations: getOccupations(figure),
    status: getStatusLabel(figure.data.dateStatus),
    summary: figure.data.summary ?? "",
    type: "life",
    href: `/${figure.id}`,
    scope: "person",
    layer: "personal",
  };
});
const workRows = figures.flatMap((figure) =>
  figure.data.importantWorks
    ?.filter((work) => typeof workYear(work) === "number")
    .map((work) => ({
      id: `${figure.id}-${workTitle(work)}`,
      figureId: figure.id,
      name: workTitle(work),
      figureName: figure.data.name,
      startYear: workYear(work),
      endYear: workEndYear(work),
      label: [workYear(work), workEndYear(work)]
        .filter((year, index, years) => typeof year === "number" && years.indexOf(year) === index)
        .map((year) => formatYear(year))
        .join("-") || "Unknown date",
      era: figure.data.era ?? "Unknown era",
      themes: figure.data.themes ?? [],
      occupations: getOccupations(figure),
      status: getStatusLabel(workStatus(work) ?? figure.data.sourceCoverageStatus),
      summary: workNote(work),
      type: "work",
      href: `/${figure.id}`,
      scope: "person",
      layer: "impact",
    })) ?? []
);
const placeRows = figures.flatMap((figure) =>
  figure.data.places
    ?.filter((place) => typeof place.startYear === "number" || typeof place.endYear === "number")
    .map((place) => ({
      id: `${figure.id}-${place.name}-${place.startYear ?? place.endYear}`,
      figureId: figure.id,
      name: place.name,
      figureName: figure.data.name,
      startYear: place.startYear ?? place.endYear,
      endYear: place.endYear ?? place.startYear,
      label: [place.startYear, place.endYear]
        .filter((year, index, years) => typeof year === "number" && years.indexOf(year) === index)
        .map((year) => formatYear(year))
        .join("-") || "Unknown date",
      era: figure.data.era ?? "Unknown era",
      themes: figure.data.themes ?? [],
      occupations: getOccupations(figure),
      status: getStatusLabel(place.status),
      summary: place.note ?? "",
      type: "place",
      href: `/${figure.id}`,
      scope: "person",
      layer: "personal",
    })) ?? []
);
const eventRows = figures.flatMap((figure) =>
  figure.data.contextEvents?.map((event) => {
    const layer = getContextLayer(event);

    return {
      id: `${figure.id}-${event.label}`,
      figureId: figure.id,
      name: event.label,
      figureName: figure.data.name,
      startYear: event.year ?? event.startYear,
      endYear: event.endYear ?? event.year ?? event.startYear,
      label: [event.year ?? event.startYear, event.endYear].filter((year) => typeof year === "number").map((year) => formatYear(year)).join("-") || "Unknown date",
      era: figure.data.era ?? "Unknown era",
      themes: figure.data.themes ?? [],
      occupations: getOccupations(figure),
      status: getStatusLabel(event.status),
      summary: event.note ?? "",
      type: "event",
      href: `/${figure.id}`,
      source: event.source ?? "",
      thread: event.thread ?? "",
      importance: event.importance ?? "supporting",
      scope: "context",
      layer,
      layerLabel: contextLayerLabels[layer],
    };
  }) ?? []
);
const seedRows = figures.flatMap((figure) =>
  figure.data.storySeeds
    ?.filter((seed) => typeof seedYear(seed) === "number")
    .map((seed) => ({
      id: `${figure.id}-story-${seed.title}`,
      figureId: figure.id,
      name: seed.title,
      figureName: figure.data.name,
      startYear: seedYear(seed),
      endYear: seedEndYear(seed),
      label: [seedYear(seed), seedEndYear(seed)]
        .filter((year, index, years) => typeof year === "number" && years.indexOf(year) === index)
        .map((year) => formatYear(year))
        .join("-") || "Unknown date",
      era: figure.data.era ?? "Unknown era",
      themes: figure.data.themes ?? [],
      occupations: getOccupations(figure),
      status: getStatusLabel(seed.status),
      summary: seed.prompt,
      note: seed.note ?? "",
      type: "story",
      href: `/${figure.id}`,
      source: seed.source ?? "",
      thread: seed.title,
      importance: "major",
      scope: "person",
      layer: "impact",
      layerLabel: contextLayerLabels.impact,
    })) ?? []
);
const rows = [...figureRows, ...workRows, ...placeRows, ...eventRows, ...seedRows].sort((a, b) => {
  const aYear = typeof a.startYear === "number" ? a.startYear : Number.POSITIVE_INFINITY;
  const bYear = typeof b.startYear === "number" ? b.startYear : Number.POSITIVE_INFINITY;
  return aYear - bYear;
});
const datedRows = rows.filter((row) => typeof row.startYear === "number");
const minYear = Math.min(...datedRows.map((row) => row.startYear ?? 0));
const maxYear = Math.max(new Date().getFullYear(), ...datedRows.map((row) => row.endYear ?? row.startYear ?? 0));
const range = Math.max(1, maxYear - minYear);
const eras = [...new Set(figureRows.map((row) => row.era))].sort();
const themes = [...new Set(figureRows.flatMap((row) => row.themes))].sort();
const eraRanges = eras
  .map((era) => {
    const eraRows = datedRows.filter((row) => row.era === era);
    const startYear = Math.max(minYear, Math.min(maxYear, Math.min(...eraRows.map((row) => row.startYear ?? 0))));
    const endYear = Math.max(startYear, Math.min(maxYear, Math.max(...eraRows.map((row) => row.endYear ?? row.startYear ?? 0))));

    return {
      era,
      startYear,
      endYear,
      count: eraRows.length,
    };
  })
  .filter((era) => Number.isFinite(era.startYear) && Number.isFinite(era.endYear))
  .sort((a, b) => a.startYear - b.startYear)
  .map((era, index) => ({ ...era, ribbonRow: index % 3 }));
const yearBuckets = new Map<number, number>();
for (const row of datedRows) {
  const bucket = Math.floor((row.startYear ?? 0) / 50) * 50;
  yearBuckets.set(bucket, (yearBuckets.get(bucket) ?? 0) + 1);
}
const denseYear = [...yearBuckets.entries()].sort((a, b) => b[1] - a[1])[0]?.[0] ?? minYear;
const importantYear = datedRows.find((row) => row.type === "event")?.startYear ?? denseYear;
type TimelineScale = {
  percentFor: (year?: number) => number;
};
const linearScale: TimelineScale = {
  percentFor: (year?: number) =>
    typeof year === "number"
      ? Math.min(100, Math.max(0, ((year - minYear) / range) * 100))
      : 0,
};
const segmentSize = 100;
const segmentStart = Math.floor(minYear / segmentSize) * segmentSize;
const segmentEnd = Math.ceil(maxYear / segmentSize) * segmentSize;
const rawSegments = Array.from({ length: Math.max(1, Math.ceil((segmentEnd - segmentStart) / segmentSize)) }, (_, index) => {
  const startYear = segmentStart + index * segmentSize;
  const endYear = Math.min(segmentEnd, startYear + segmentSize);
  const count = datedRows.filter((row) => {
    const year = row.startYear;
    return typeof year === "number" && year >= startYear && year < endYear;
  }).length;

  return {
    startYear,
    endYear,
    count,
    weight: count > 0 ? 0.45 + Math.sqrt(count) : 0.22,
  };
});
const totalSegmentWeight = rawSegments.reduce((total, segment) => total + segment.weight, 0) || 1;
let readableCursor = 0;
const readableSegments = rawSegments.map((segment) => {
  const startPercent = readableCursor;
  readableCursor += (segment.weight / totalSegmentWeight) * 100;
  return {
    ...segment,
    startPercent,
    endPercent: readableCursor,
  };
});
const readableScale: TimelineScale = {
  percentFor: (year?: number) => {
    if (typeof year !== "number") return 0;
    const clampedYear = Math.min(segmentEnd, Math.max(segmentStart, year));
    const segment =
      readableSegments.find((candidate) => clampedYear >= candidate.startYear && clampedYear < candidate.endYear) ??
      readableSegments[readableSegments.length - 1];
    const segmentRange = Math.max(1, segment.endYear - segment.startYear);
    const segmentPercent = Math.min(1, Math.max(0, (clampedYear - segment.startYear) / segmentRange));

    return Math.min(100, Math.max(0, segment.startPercent + (segment.endPercent - segment.startPercent) * segmentPercent));
  },
};
const positionFor = (scale: TimelineScale, year?: number) => scale.percentFor(year).toFixed(2);
const tickCount = 5;
const yearTicks = Array.from({ length: tickCount }, (_, index) =>
  Math.round(minYear + (range * index) / (tickCount - 1))
);
const readableSegmentLabels = readableSegments.filter((segment, index) => {
  if (index === 0 || index === readableSegments.length - 1) return true;
  if (segment.count === 0) return false;

  const previousLabel = readableSegments
    .slice(0, index)
    .reverse()
    .find((candidate, candidateIndex) => {
      const originalIndex = index - candidateIndex - 1;
      return originalIndex === 0 || candidate.count > 0;
    });

  return !previousLabel || segment.startPercent - previousLabel.startPercent >= 9;
});
const eraSurfaceLabel = (era: string) => {
  const compact = era
    .replace(/\([^)]*\)/g, "")
    .split(/\s+/)
    .filter((word) => word.length > 2)
    .map((word) => word[0])
    .join("")
    .slice(0, 4)
    .toUpperCase();

  return compact || era.slice(0, 4);
};
const laneBaseFor = (type: string) =>
  ({
    life: 25,
    work: 9,
    place: 41,
    event: 63,
    story: 83,
  })[type] ?? 50;
const typeLaneOffsets: Record<string, number[]> = {
  life: [0, -9, 9, -17, 17, -23, 23],
  work: [0, 9, -7, 17, -15],
  place: [0, -9, 9, -17, 17],
  event: [0, 9, -9, 17, -17, 23, -23],
  story: [0, -9, 9, -17, 17],
};
const clusterKeyFor = (year: number | undefined, type: string, scale: TimelineScale) => {
  const x = scale.percentFor(year);
  const cluster = typeof year === "number" ? Math.round(x / 1.2) : 0;

  return `${type}-${cluster}`;
};
const clusterCountsFor = (scale: TimelineScale) => {
  const counts = new Map<string, number>();

  for (const row of rows) {
    const key = clusterKeyFor(row.startYear, row.type, scale);
    counts.set(key, (counts.get(key) ?? 0) + 1);
  }

  return counts;
};
const placementFor = (
  year: number | undefined,
  type: string,
  scale: TimelineScale,
  laneIndexByCluster: Map<string, number>,
  clusterCounts: Map<string, number>
) => {
  const x = scale.percentFor(year);
  const key = clusterKeyFor(year, type, scale);
  const index = laneIndexByCluster.get(key) ?? 0;
  laneIndexByCluster.set(key, index + 1);

  const offsets = typeLaneOffsets[type] ?? [0, -7, 7];
  const offset = offsets[index % offsets.length];
  const wrap = Math.floor(index / offsets.length);
  const baseY = laneBaseFor(type);
  const y = Math.min(85, Math.max(15, baseY + offset + wrap * 5));
  const clusterCount = clusterCounts.get(key) ?? 1;

  return { x: `${x.toFixed(2)}%`, y: `${y.toFixed(2)}%`, clusterCount, clusterIndex: index };
};
const readableLaneIndexByCluster = new Map<string, number>();
const linearLaneIndexByCluster = new Map<string, number>();
const readableClusterCounts = clusterCountsFor(readableScale);
const linearClusterCounts = clusterCountsFor(linearScale);
---

<BaseLayout title="Archive Timeline" description={`Explore the ${siteConfig.title} by year.`} canonicalPath="/timeline">
  <SiteHeader />

  <section class="archive-hero">
    <div>
      <span class="beta-label">Timeline beta</span>
      <p>Lifespans, works, moves, and context events arranged across the archive.</p>
      <p class="reliability-note">{reliabilityCopy}</p>
    </div>
  </section>

  <section class="search-section timeline-controls">
    <div class="search-row">
      <label>
        Search
        <input id="timeline-search" type="search" placeholder="Try science, London, resistance..." autocomplete="off" />
      </label>

      <div class="timeline-mode-control" aria-label="Timeline scale mode">
        <span>Scale</span>
        <button type="button" data-timeline-mode="readable" aria-pressed="true">Readable</button>
        <button type="button" data-timeline-mode="linear" aria-pressed="false">Linear</button>
      </div>

      <button
        type="button"
        id="timeline-filters-toggle"
        class="filters-toggle"
        aria-expanded="false"
      >
        Show Filters
      </button>
    </div>

    <div id="timeline-thread-chip" class="timeline-active-chip hidden" aria-live="polite">
      <span>Thread: <strong data-thread-chip-label></strong></span>
      <button type="button" data-thread-chip-clear aria-label="Clear focused thread">Clear</button>
    </div>

    <div id="timeline-filters-panel" class="filters-panel hidden">
      <div class="filter-grid" aria-label="Timeline filters">
        <label>
          Era
          <select id="timeline-era">
            <option value="">Any era</option>
            {eras.map((era) => <option value={era}>{era}</option>)}
          </select>
        </label>

        <label>
          Theme
          <select id="timeline-theme">
            <option value="">Any theme</option>
            {themes.map((theme) => <option value={theme}>{theme}</option>)}
          </select>
        </label>

        <label>
          Type
          <select id="timeline-type">
            <option value="">All timeline notes</option>
            <option value="life">Lifespans</option>
            <option value="work">Important works</option>
            <option value="place">Place moves</option>
            <option value="event">Impact + world events</option>
            <option value="story">Historical threads</option>
          </select>
        </label>
      </div>

      <div class="collection-chips timeline-layer-controls" aria-label="Timeline layers">
        <span>Layers</span>
        <label class="context-toggle">
          <input type="checkbox" data-timeline-layer="personal" checked />
          {contextLayerLabels.personal}
        </label>
        <label class="context-toggle">
          <input type="checkbox" data-timeline-layer="impact" checked />
          {contextLayerLabels.impact}
        </label>
        <label class="context-toggle">
          <input type="checkbox" data-timeline-layer="world" checked />
          {contextLayerLabels.world}
        </label>
      </div>

      <div class="timeline-zoom-controls" aria-label="Timeline zoom controls">
        <button type="button" data-timeline-zoom="out">Full range</button>
        <button type="button" data-timeline-zoom="life">Lives</button>
        <button type="button" data-timeline-zoom="dense">Dense years</button>
      </div>

      <div class="timeline-era-band" aria-label="Timeline era focus">
        <button type="button" data-era-focus="">All eras</button>
        {eraRanges.map((era) => (
          <button
            type="button"
            data-era-focus={era.era}
            data-era-year={era.startYear}
          >
            <strong>{era.era}</strong>
            <span>{formatYear(era.startYear)}-{formatYear(era.endYear)} · {era.count}</span>
          </button>
        ))}
      </div>

      <div class="collection-chips" aria-label="Start somewhere">
        <span>Start somewhere</span>
        <button type="button" data-jump-year={denseYear}>Dense years</button>
        <button type="button" data-jump-year={importantYear}>Important years</button>
        <button type="button" data-theme-query="Science and Innovation">Scientists</button>
        <button type="button" data-theme-query="Power and Resistance">Resistance</button>
      </div>
    </div>
  </section>

  <section class="timeline-board">
    <div class="timeline-type-key" aria-label="Timeline marker key">
      <span class="life">Lives</span>
      <span class="work">Works</span>
      <span class="place">Places</span>
      <span class="event impact">Impact</span>
      <span class="event world">World</span>
      <span class="story">Threads</span>
    </div>

    <section class="timeline-scale" style={`--min-year: ${minYear}; --max-year: ${maxYear};`} data-scale-mode="readable">
      <div class="timeline-scale-note">Readable mode compresses sparse centuries and expands crowded ones.</div>

      <div class="timeline-segments" aria-hidden="true">
        {readableSegmentLabels.map((segment) => (
          <span
            style={`--segment-start: ${segment.startPercent.toFixed(2)}%; --segment-end: ${segment.endPercent.toFixed(2)}%;`}
            title={`${formatYear(segment.startYear)}-${formatYear(segment.endYear)} · ${segment.count} entries`}
          >
            {formatYear(segment.startYear)}
          </span>
        ))}
      </div>

      <div class="timeline-axis" aria-hidden="true">
        {yearTicks.map((year) => (
          <span
            style={`--tick: ${positionFor(readableScale, year)}%;`}
            data-readable-tick={`${positionFor(readableScale, year)}%`}
            data-linear-tick={`${positionFor(linearScale, year)}%`}
          >
            {formatYear(year)}
          </span>
        ))}
      </div>

      <div class="timeline-era-ribbons" aria-label="Timeline era bands">
        {eraRanges.map((era) => (
          <span
            style={`--era-start: ${positionFor(readableScale, era.startYear)}%; --era-end: ${positionFor(readableScale, era.endYear)}%; --era-row: ${era.ribbonRow};`}
            data-readable-era-start={`${positionFor(readableScale, era.startYear)}%`}
            data-readable-era-end={`${positionFor(readableScale, era.endYear)}%`}
            data-linear-era-start={`${positionFor(linearScale, era.startYear)}%`}
            data-linear-era-end={`${positionFor(linearScale, era.endYear)}%`}
            title={`${era.era}: ${formatYear(era.startYear)}-${formatYear(era.endYear)}`}
          >
            {eraSurfaceLabel(era.era)}
          </span>
        ))}
      </div>

      <ol class="timeline-rows single-line-timeline" data-zoom="out" data-dense-year={denseYear}>
        {rows.map((row) => {
          const readablePlacement = placementFor(
            row.startYear,
            row.type,
            readableScale,
            readableLaneIndexByCluster,
            readableClusterCounts
          );
          const linearPlacement = placementFor(
            row.startYear,
            row.type,
            linearScale,
            linearLaneIndexByCluster,
            linearClusterCounts
          );
          const readableClusterLabel =
            readablePlacement.clusterCount >= 4 && readablePlacement.clusterIndex === 0
              ? `${readablePlacement.clusterCount}`
              : undefined;

          return (
            <li
              id={row.type === "life" ? row.id : undefined}
              class={`timeline-row ${row.type}`}
              data-era={row.era}
              data-themes={row.themes.join("|")}
              data-type={row.type}
              data-scope={row.scope}
              data-layer={row.layer}
              data-layer-label={"layerLabel" in row ? row.layerLabel : contextLayerLabels[row.layer]}
              data-thread={"thread" in row ? row.thread : ""}
              data-importance={"importance" in row ? row.importance : ""}
              data-year={row.startYear ?? ""}
              data-end-year={row.endYear ?? row.startYear ?? ""}
              data-name={row.name}
              data-figure={"figureName" in row ? row.figureName : row.name}
              data-label={row.label}
              data-status={row.status}
              data-summary={row.summary}
              data-href={row.href}
              data-source={"source" in row ? row.source : ""}
              data-search={`${row.name} ${"figureName" in row ? row.figureName : ""} ${row.label} ${row.summary} ${row.era} ${row.themes.join(" ")} ${row.occupations.join(" ")} ${row.type} ${row.scope} ${row.layer} ${"thread" in row ? row.thread : ""}`}
              style={`--start: ${positionFor(readableScale, row.startYear)}%; --end: ${positionFor(readableScale, row.endYear)}%; --pin-x: ${readablePlacement.x}; --pin-y: ${readablePlacement.y};`}
              data-readable-start={`${positionFor(readableScale, row.startYear)}%`}
              data-readable-end={`${positionFor(readableScale, row.endYear)}%`}
              data-readable-pin-x={readablePlacement.x}
              data-readable-pin-y={readablePlacement.y}
              data-readable-cluster-count={readableClusterLabel}
              data-linear-start={`${positionFor(linearScale, row.startYear)}%`}
              data-linear-end={`${positionFor(linearScale, row.endYear)}%`}
              data-linear-pin-x={linearPlacement.x}
              data-linear-pin-y={linearPlacement.y}
              data-linear-cluster-count={
                linearPlacement.clusterCount >= 4 && linearPlacement.clusterIndex === 0
                  ? `${linearPlacement.clusterCount}`
                  : undefined
              }
            >
              <button type="button" class="timeline-bar">
                <span class="timeline-pin-dot" aria-hidden="true"></span>
                <strong>{row.name}</strong>
                {"figureName" in row && <span>{row.figureName}</span>}
              </button>
              <div class="timeline-meta">
                <span>{row.label}</span>
                <span class="status-pill">{row.status}</span>
              </div>
            </li>
          );
        })}
      </ol>
    </section>

    <aside class="timeline-detail" id="timeline-detail" aria-live="polite" tabindex="-1">
      <span class="beta-label">Timeline focus</span>
      <h3>Select a life, work, place, event, or thread</h3>
      <p class="muted">Use search, filters, or the quick chips to narrow the timeline, then select a marker to see sources and who was alive nearby.</p>
    </aside>
  </section>

  {seedRows.length > 0 && (
    <section class="story-seeds" aria-labelledby="story-seeds-heading">
      <div class="section-heading">
        <div>
          <span class="beta-label">Curated threads</span>
          <h3 id="story-seeds-heading">Historical threads ready for timeline browsing</h3>
        </div>
        <span>{seedRows.length} sourced prompts</span>
      </div>

      <ol class="story-seed-list">
        {seedRows.map((seed) => (
          <li>
            <a href={seed.href}>
              <strong>{seed.name}</strong>
              <span>{seed.figureName} · {seed.label}</span>
            </a>
            <p>{seed.summary}</p>
            {seed.note && <small>{seed.note}</small>}
            <div class="story-seed-meta">
              <span class="status-pill">{seed.status}</span>
              <a href={`/timeline?thread=${encodeURIComponent(seed.thread)}#${seed.id}`}>Open thread</a>
              {seed.source && <a href={seed.source}>Source</a>}
            </div>
          </li>
        ))}
      </ol>
    </section>
  )}

  <SiteFooter />
</BaseLayout>

<script>
  const eraFilter = document.getElementById("timeline-era") as HTMLSelectElement | null;
  const themeFilter = document.getElementById("timeline-theme") as HTMLSelectElement | null;
  const typeFilter = document.getElementById("timeline-type") as HTMLSelectElement | null;
  const timelineSearch = document.getElementById("timeline-search") as HTMLInputElement | null;
  const layerToggles = document.querySelectorAll<HTMLInputElement>("[data-timeline-layer]");
  const detail = document.getElementById("timeline-detail");
  const rows = document.querySelectorAll<HTMLElement>(".timeline-row");
  const timeline = document.querySelector<HTMLElement>(".single-line-timeline");
  const jumpButtons = document.querySelectorAll<HTMLButtonElement>("[data-jump-year]");
  const themeButtons = document.querySelectorAll<HTMLButtonElement>("[data-theme-query]");
  const zoomButtons = document.querySelectorAll<HTMLButtonElement>("[data-timeline-zoom]");
  const eraButtons = document.querySelectorAll<HTMLButtonElement>("[data-era-focus]");
  const filtersToggle = document.getElementById("timeline-filters-toggle");
  const filtersPanel = document.getElementById("timeline-filters-panel");
  const modeButtons = document.querySelectorAll<HTMLButtonElement>("[data-timeline-mode]");
  const scaleBoard = document.querySelector<HTMLElement>(".timeline-scale");
  const threadChip = document.getElementById("timeline-thread-chip");
  const threadChipLabel = threadChip?.querySelector<HTMLElement>("[data-thread-chip-label]");
  const threadChipClear = threadChip?.querySelector<HTMLButtonElement>("[data-thread-chip-clear]");

  const setTimelineMode = (mode: "readable" | "linear") => {
    scaleBoard?.setAttribute("data-scale-mode", mode);

    modeButtons.forEach((button) => {
      button.setAttribute("aria-pressed", String(button.dataset.timelineMode === mode));
    });

    document.querySelectorAll<HTMLElement>("[data-readable-tick][data-linear-tick]").forEach((tick) => {
      tick.style.setProperty("--tick", mode === "linear" ? tick.dataset.linearTick ?? "0%" : tick.dataset.readableTick ?? "0%");
    });

    document.querySelectorAll<HTMLElement>("[data-readable-era-start][data-linear-era-start]").forEach((era) => {
      era.style.setProperty("--era-start", mode === "linear" ? era.dataset.linearEraStart ?? "0%" : era.dataset.readableEraStart ?? "0%");
      era.style.setProperty("--era-end", mode === "linear" ? era.dataset.linearEraEnd ?? "0%" : era.dataset.readableEraEnd ?? "0%");
    });

    rows.forEach((row) => {
      row.style.setProperty("--start", mode === "linear" ? row.dataset.linearStart ?? "0%" : row.dataset.readableStart ?? "0%");
      row.style.setProperty("--end", mode === "linear" ? row.dataset.linearEnd ?? "0%" : row.dataset.readableEnd ?? "0%");
      row.style.setProperty("--pin-x", mode === "linear" ? row.dataset.linearPinX ?? "0%" : row.dataset.readablePinX ?? "0%");
      row.style.setProperty("--pin-y", mode === "linear" ? row.dataset.linearPinY ?? "50%" : row.dataset.readablePinY ?? "50%");
      const clusterCount = mode === "linear" ? row.dataset.linearClusterCount : row.dataset.readableClusterCount;
      if (clusterCount) {
        row.dataset.clusterCount = clusterCount;
      } else {
        delete row.dataset.clusterCount;
      }
    });
  };

  modeButtons.forEach((button) => {
    button.addEventListener("click", () => {
      setTimelineMode(button.dataset.timelineMode === "linear" ? "linear" : "readable");
    });
  });

  const applyFilters = () => {
    const era = eraFilter?.value ?? "";
    const theme = themeFilter?.value ?? "";
    const type = typeFilter?.value ?? "";
    const query = timelineSearch?.value.toLowerCase().trim() ?? "";
    const activeLayers = new Set(
      [...layerToggles]
        .filter((toggle) => toggle.checked)
        .map((toggle) => toggle.dataset.timelineLayer ?? "")
    );

    rows.forEach((row) => {
      const themes = row.dataset.themes?.split("|") ?? [];
      const searchText = row.dataset.search?.toLowerCase() ?? "";
      const matches =
        (!era || row.dataset.era === era) &&
        (!theme || themes.includes(theme)) &&
        (!type || row.dataset.type === type) &&
        activeLayers.has(row.dataset.layer ?? "") &&
        (!query || searchText.includes(query));

      row.classList.toggle("hidden", !matches);
    });
  };

  [eraFilter, themeFilter, typeFilter].forEach((control) => {
    control?.addEventListener("change", applyFilters);
  });
  timelineSearch?.addEventListener("input", applyFilters);
  layerToggles.forEach((toggle) => toggle.addEventListener("change", applyFilters));

  const renderDetail = (row: HTMLElement) => {
    if (!detail) return;
    const year = Number(row.dataset.year ?? "");
    const alive = [...rows]
      .filter((candidate) => candidate.dataset.type === "life")
      .filter((candidate) => {
        const start = Number(candidate.dataset.year ?? "");
        const end = Number(candidate.dataset.endYear ?? candidate.dataset.year ?? "");
        return Number.isFinite(year) && Number.isFinite(start) && Number.isFinite(end) && start <= year && end >= year;
      })
      .map((candidate) => candidate.dataset.name)
      .filter(Boolean)
      .slice(0, 8);

    const source = row.dataset.source
      ? `<a href="${row.dataset.source}">Open source</a>`
      : "";

    detail.innerHTML = `
      <span class="beta-label">${row.dataset.type === "story" ? "Historical thread" : row.dataset.layerLabel || "Timeline moment"}</span>
      <h3>${row.dataset.name}</h3>
      <p><strong>${row.dataset.figure}</strong> · ${row.dataset.label}</p>
      <p>${row.dataset.summary || "No note yet."}</p>
      <span class="status-pill">${row.dataset.status}</span>
      ${row.dataset.thread ? `<p class="muted"><strong>Thread:</strong> ${row.dataset.thread}</p>` : ""}
      <div class="timeline-detail-links">
        <a href="${row.dataset.href}">Open profile</a>
        ${source}
      </div>
      ${
        alive.length
          ? `<div class="timeline-alive"><strong>Alive around ${row.dataset.label}</strong><span>${alive.join(", ")}</span></div>`
          : ""
      }
    `;
    rows.forEach((candidate) => {
      const selected = candidate === row;
      candidate.classList.toggle("selected", selected);
      candidate.querySelector(".timeline-bar")?.setAttribute("aria-pressed", String(selected));
    });
    detail.focus({ preventScroll: true });
  };

  rows.forEach((row) => {
    row.querySelector(".timeline-bar")?.addEventListener("click", () => renderDetail(row));
    row.addEventListener("click", (event) => {
      if (event.target instanceof HTMLElement && event.target.closest(".timeline-bar")) return;
      renderDetail(row);
    });
  });

  jumpButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const targetYear = Number(button.dataset.jumpYear ?? "");
      const target = [...rows].find((row) => Number(row.dataset.year) >= targetYear);
      target?.scrollIntoView({ behavior: "smooth", block: "nearest", inline: "center" });
    });
  });

  themeButtons.forEach((button) => {
    button.addEventListener("click", () => {
      if (!themeFilter) return;
      themeFilter.value = button.dataset.themeQuery ?? "";
      applyFilters();
    });
  });

  zoomButtons.forEach((button) => {
    button.addEventListener("click", () => {
      if (!timeline) return;
      timeline.dataset.zoom = button.dataset.timelineZoom ?? "out";
      if (button.dataset.timelineZoom === "dense") {
        const target = [...rows].find((row) => Number(row.dataset.year) >= Number(timeline.dataset.denseYear ?? ""));
        target?.scrollIntoView({ behavior: "smooth", block: "nearest", inline: "center" });
      }
    });
  });

  eraButtons.forEach((button) => {
    button.addEventListener("click", () => {
      if (eraFilter) {
        eraFilter.value = button.dataset.eraFocus ?? "";
      }
      applyFilters();
      const targetYear = Number(button.dataset.eraYear ?? "");
      const target = [...rows].find((row) => {
        const visible = !row.classList.contains("hidden");
        const rowYear = Number(row.dataset.year ?? "");
        return visible && (!Number.isFinite(targetYear) || rowYear >= targetYear);
      });
      target?.scrollIntoView({ behavior: "smooth", block: "nearest", inline: "center" });
    });
  });

  const clearThreadFocus = () => {
    rows.forEach((row) => row.classList.remove("thread-focused"));
    threadChip?.classList.add("hidden");
  };

  const focusThread = (thread: string) => {
    const normalizedThread = thread.toLowerCase().trim();
    const matchingRows = [...rows].filter((row) => (row.dataset.thread ?? "").toLowerCase().trim() === normalizedThread);

    if (threadChip && threadChipLabel) {
      threadChipLabel.textContent = thread;
      threadChip.classList.remove("hidden");
    }

    rows.forEach((row) => row.classList.toggle("thread-focused", matchingRows.includes(row)));

    const firstMatch = matchingRows.find((row) => !row.classList.contains("hidden")) ?? matchingRows[0];
    if (firstMatch) {
      renderDetail(firstMatch);
      firstMatch.scrollIntoView({ behavior: "smooth", block: "nearest", inline: "center" });
      firstMatch.querySelector<HTMLButtonElement>(".timeline-bar")?.focus({ preventScroll: true });
    }
  };

  setTimelineMode("readable");
  applyFilters();

  const params = new URLSearchParams(window.location.search);
  const thread = params.get("thread");
  if (thread) {
    focusThread(thread);
  }

  threadChipClear?.addEventListener("click", () => {
    clearThreadFocus();
    const url = new URL(window.location.href);
    url.searchParams.delete("thread");
    history.replaceState(null, "", `${url.pathname}${url.search}${url.hash}`);
    timelineSearch?.focus({ preventScroll: true });
  });

  filtersToggle?.addEventListener("click", () => {
    const isOpen = !filtersPanel?.classList.contains("hidden");

    filtersPanel?.classList.toggle("hidden");
    filtersToggle.textContent = isOpen ? "Show Filters" : "Hide Filters";
    filtersToggle.setAttribute("aria-expanded", String(!isOpen));
  });
</script>
