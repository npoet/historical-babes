---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro"
import SiteFooter from "../components/SiteFooter.astro"
import { siteConfig } from "../site.config";
import {
  getOccupations,
  getReferenceTypeData,
  getSearchBucketData,
  getSearchText,
  getStartYear,
  reliabilityCopy,
  sourceFilterOptions,
} from "../lib/figures";

const figures = await getCollection("figures");

figures.sort((a, b) =>
  a.data.name.localeCompare(b.data.name)
);

const eras = [...new Set(figures.map((figure) => figure.data.era).filter(Boolean))].sort();
const occupations = [
  ...new Set(figures.flatMap((figure) => getOccupations(figure)).filter(Boolean)),
].sort();
const themes = [
  ...new Set(figures.flatMap((figure) => figure.data.themes ?? []).filter(Boolean)),
].sort();
const places = [
  ...new Set(figures.flatMap((figure) => figure.data.places?.map((place) => place.name) ?? []).filter(Boolean)),
].sort();
const makeExplorationPrompt = ({
  label,
  kind,
  query = "",
  era = "",
  theme = "",
  source = "",
}: {
  label: string;
  kind: string;
  query?: string;
  era?: string;
  theme?: string;
  source?: string;
}) => ({ label, kind, query, era, theme, source });
const explorationPrompts = [
  ...themes.slice(0, 2).map((theme) => makeExplorationPrompt({
    label: theme,
    kind: "Theme",
    query: theme,
    theme,
  })),
  ...places.slice(0, 2).map((place) => makeExplorationPrompt({
    label: place,
    kind: "Place",
    query: place,
  })),
  ...eras.slice(0, 2).map((era) => makeExplorationPrompt({
    label: era,
    kind: "Era",
    era,
  })),
  makeExplorationPrompt({
    label: "Museum/archive",
    kind: "Source",
    source: "museum|archive",
  }),
  makeExplorationPrompt({
    label: "Historical thread",
    kind: "Thread",
    query: "historical thread",
  }),
];
const timelineFigures = figures
  .map((figure) => ({
    figure,
    startYear: getStartYear(figure),
  }))
  .filter((item) => typeof item.startYear === "number")
  .sort((a, b) => (a.startYear ?? 0) - (b.startYear ?? 0));
const mappedPlaces = figures.flatMap((figure) =>
  figure.data.places
    ?.filter((place) => typeof place.latitude === "number" && typeof place.longitude === "number")
    .map((place) => ({
      figure,
      place,
      latitude: place.latitude ?? 0,
      longitude: place.longitude ?? 0,
      label: place.name,
      note: place.note,
      kind: place.type ?? "place",
    })) ?? []
);
const coordinateByPlace = new Map(
  mappedPlaces.map((item) => [
    item.place.name,
    {
      latitude: item.latitude,
      longitude: item.longitude,
    },
  ])
);
const contextEventPlaces = figures.flatMap((figure) =>
  figure.data.contextEvents
    ?.filter((event) => event.place)
    .map((event) => {
      const coordinates = coordinateByPlace.get(event.place ?? "");

      return {
        figure,
        event,
        coordinates,
      };
    }) ?? []
);
const eventMarkers = contextEventPlaces
  .filter((item) => item.coordinates)
  .map(({ figure, event, coordinates }) => ({
    figure,
    latitude: coordinates?.latitude ?? 0,
    longitude: coordinates?.longitude ?? 0,
    label: event.place ?? event.label,
    note: event.note,
    kind: "event",
    eventLabel: event.label,
  }));
const mapMarkers = [...mappedPlaces, ...eventMarkers].sort((a, b) =>
  a.figure.data.name.localeCompare(b.figure.data.name)
);
const mapGroups = figures
  .map((figure) => ({
    figure,
    markers: mapMarkers.filter((marker) => marker.figure.id === figure.id),
  }))
  .filter((group) => group.markers.length > 0)
  .sort((a, b) => b.markers.length - a.markers.length || a.figure.data.name.localeCompare(b.figure.data.name));
const missingCoordinateItems = [
  ...figures.flatMap((figure) =>
    figure.data.places
      ?.filter((place) => typeof place.latitude !== "number" || typeof place.longitude !== "number")
      .map((place) => ({
        figure,
        label: place.name,
        note: place.note ?? "Place metadata is present, but coordinates have not been reviewed yet.",
      })) ?? []
  ),
  ...contextEventPlaces
    .filter((item) => !item.coordinates)
    .map(({ figure, event }) => ({
      figure,
      label: event.place ?? event.label,
      note: `${event.label} has a place note but no reviewed coordinates yet.`,
    })),
];
---

<BaseLayout
  title="All Babes"
  description={`Search and filter ${figures.length} entries in the ${siteConfig.title}.`}
  canonicalPath="/all"
>
 <SiteHeader />
  <section class="archive-hero">
    <div>
      <span class="beta-label">Archive beta</span>
      <h2>Archive</h2>
      <p>
        Search names, places, eras, occupations, themes, and notes across the growing Historical Babes collection.
      </p>
      <p class="reliability-note">{reliabilityCopy}</p>
    </div>

    <div class="creator-cta compact">
      <span>More research and process notes from {siteConfig.creator.name}</span>
      <div class="cta-links">
        <a href={siteConfig.creator.instagramUrl} target="_blank" rel="noopener noreferrer">Instagram</a>
        <a href={siteConfig.creator.linkedInUrl} target="_blank" rel="noopener noreferrer">LinkedIn</a>
      </div>
    </div>
  </section>

  <section class="search-section">
      <input
        id="figure-search"
        type="search"
        placeholder="Search names, places, occupations, themes, context..."
        class="search-input"
        aria-label="Search historical figures"
      />
      <p class="search-scope-note">
        Deep search includes figure summaries, places, source-linked context events, and research notes.
      </p>

      <div class="collection-chips" aria-label="Start somewhere">
        <span>Start somewhere</span>
        <button type="button" data-chip-query="scientist physicist chemist science">Scientists</button>
        <button type="button" data-chip-query="artist writer art">Artists</button>
        <button type="button" data-chip-query="resistance civil rights activist">Resistance</button>
        <button type="button" data-chip-query="first pioneer">Firsts</button>
        <button type="button" data-chip-query="war conflict resistance">War + Conflict</button>
      </div>

      <div class="collection-chips" aria-label="Keep exploring">
        <span>Keep exploring</span>
        {explorationPrompts.map((prompt) => (
          <button
            type="button"
            data-chip-query={prompt.query}
            data-chip-era={prompt.era}
            data-chip-theme={prompt.theme}
            data-chip-source={prompt.source}
          >
            <small>{prompt.kind}</small>
            {prompt.label}
          </button>
        ))}
      </div>

      <div class="filter-grid" aria-label="Archive filters">
        <label>
          Era
          <select id="era-filter">
            <option value="">Any era</option>
            {eras.map((era) => <option value={era}>{era}</option>)}
          </select>
        </label>

        <label>
          Occupation
          <select id="occupation-filter">
            <option value="">Any occupation</option>
            {occupations.map((occupation) => <option value={occupation}>{occupation}</option>)}
          </select>
        </label>

        <label>
          Theme
          <select id="theme-filter">
            <option value="">Any theme</option>
            {themes.map((theme) => <option value={theme}>{theme}</option>)}
          </select>
        </label>

        <label>
          Source type
          <select id="source-filter">
            <option value="">Any source type</option>
            {sourceFilterOptions.map((option) => (
              <option value={option.value}>{option.label}</option>
            ))}
          </select>
        </label>
      </div>
  </section>
  <section id="figure-grid" class="figure-grid">
    {figures.map((figure) => (
      <a
        href={`/${figure.id}`}
        class="figure-card"
        data-search={getSearchText(figure)}
        data-search-buckets={getSearchBucketData(figure)}
        data-era={figure.data.era ?? ""}
        data-occupations={getOccupations(figure).join("|")}
        data-themes={(figure.data.themes ?? []).join("|")}
        data-sources={getReferenceTypeData(figure)}
      >
        <div class="figure-image">
          <img
            src={figure.data.image.src}
            alt={figure.data.image.alt}
            loading="lazy"
          />
        </div>

        <div class="figure-info">
          <h3>{figure.data.name}</h3>

          {
            figure.data.lifespan && (
              <span>{figure.data.lifespan}</span>
            )
          }

          {
            figure.data.summary && (
              <p>{figure.data.summary}</p>
            )
          }

          <small class="match-hint" aria-live="polite"></small>

          <span class="card-actions">
            <span>Open profile</span>
            <span class="share-card" data-share-url={`/${figure.id}`}>Share</span>
          </span>
        </div>
      </a>
    ))}
  </section>
  <div id="no-results" class="no-results hidden">
      <img
        src="/images/strange-things.gif"
        alt="No results found"
        class="no-results-image"
      />

      <p>No babes match your search.</p>
    </div>

  <section class="archive-panel">
    <div class="section-heading">
      <h3>Timeline</h3>
      <span>{timelineFigures.length} dated entries</span>
    </div>

    <ol class="timeline-list">
      {timelineFigures.map(({ figure, startYear }) => (
        <li>
          <a href={`/${figure.id}`}>{figure.data.name}</a>
          <span>{figure.data.lifespan ?? startYear}</span>
        </li>
      ))}
    </ol>
  </section>

  <section class="archive-panel">
    <div class="section-heading">
      <h3>Map</h3>
      <span>{mapMarkers.length} mapped notes, {missingCoordinateItems.length} awaiting coordinates</span>
    </div>

    {
      mapMarkers.length > 0 ? (
        <div class="archive-map" aria-label="Mapped archive places">
          <div class="archive-map-summary">
            <div>
              <span class="beta-label">Map preview</span>
              <p class="muted">Grouped by person so repeated places and events are easier to scan. Open the full map for pan, zoom, and geographic context.</p>
            </div>
            <a href="/map">Open interactive map</a>
          </div>

          <ol class="map-group-list">
            {mapGroups.map((group) => (
              <li>
                <div class="map-group-heading">
                  <img src={group.figure.data.image.src} alt="" loading="lazy" />
                  <div>
                    <a href={`/${group.figure.id}`}>{group.figure.data.name}</a>
                    <span>{group.markers.length} mapped note{group.markers.length === 1 ? "" : "s"}</span>
                  </div>
                  <a href={`/map#${group.figure.id}`}>Focus</a>
                </div>

                <ol>
                  {group.markers.slice(0, 4).map((marker) => (
                    <li>
                      <span class={`map-dot ${marker.kind === "event" ? "event" : ""}`} aria-hidden="true"></span>
                      <span>{marker.eventLabel ?? marker.label}</span>
                      {marker.eventLabel && <small>{marker.label}</small>}
                    </li>
                  ))}
                </ol>
              </li>
            ))}
          </ol>
        </div>
      ) : (
        <p class="muted">Map-ready place notes will appear here as entries gain coordinates.</p>
      )
    }

    {
      missingCoordinateItems.length > 0 && (
        <details class="missing-map-data">
          <summary>Entries with place notes awaiting reviewed coordinates</summary>

          <ul class="map-list compact">
            {missingCoordinateItems.map((item) => (
              <li>
                <a href={`/${item.figure.id}`}>{item.figure.data.name}</a>
                <span>{item.label}</span>
                <small>{item.note}</small>
              </li>
            ))}
          </ul>
        </details>
      )
    }
  </section>

  <SiteFooter />
</BaseLayout>

<script>
  const searchInput =
    document.getElementById("figure-search") as HTMLInputElement | null;
  const eraFilter =
    document.getElementById("era-filter") as HTMLSelectElement | null;
  const occupationFilter =
    document.getElementById("occupation-filter") as HTMLSelectElement | null;
  const themeFilter =
    document.getElementById("theme-filter") as HTMLSelectElement | null;
  const sourceFilter =
    document.getElementById("source-filter") as HTMLSelectElement | null;

  const cards =
    document.querySelectorAll<HTMLElement>(".figure-card");
  const chipButtons =
    document.querySelectorAll<HTMLButtonElement>("[data-chip-query]");

  const noResults =
    document.getElementById("no-results");

  const grid =
    document.getElementById("figure-grid");

  const applyFilters = () => {
    const query =
      searchInput?.value.toLowerCase().trim() ?? "";
    const era =
      eraFilter?.value ?? "";
    const occupation =
      occupationFilter?.value ?? "";
    const theme =
      themeFilter?.value ?? "";
    const sourceType =
      sourceFilter?.value ?? "";

    let visible = 0;

    cards.forEach((card) => {
      const search =
        card.dataset.search || "";
      const occupations =
        card.dataset.occupations || "";
      const themes =
        card.dataset.themes || "";
      const sources =
        card.dataset.sources || "";
      const sourceChoices =
        sourceType.split("|").filter(Boolean);
      const hint =
        card.querySelector<HTMLElement>(".match-hint");
      const buckets = JSON.parse(card.dataset.searchBuckets || "[]") as {
        label: string;
        text: string;
      }[];

      const match =
        search.includes(query) &&
        (!era || card.dataset.era === era) &&
        (!occupation || occupations.split("|").includes(occupation)) &&
        (!theme || themes.split("|").includes(theme)) &&
        (!sourceChoices.length || sourceChoices.some((type) => sources.split("|").includes(type)));

      card.style.display =
        match ? "" : "none";

      if (hint) {
        const matchedBuckets = query
          ? buckets
              .filter((bucket) => bucket.text.includes(query))
              .map((bucket) => bucket.label)
              .slice(0, 3)
          : [];

        hint.textContent = matchedBuckets.length
          ? `Matched in ${matchedBuckets.join(", ")}`
          : "";
      }

      if (match) visible++;
    });

    if (visible === 0) {
      noResults?.classList.remove("hidden");
      grid?.classList.add("hidden");
    } else {
      noResults?.classList.add("hidden");
      grid?.classList.remove("hidden");
    }
  };

  [searchInput, eraFilter, occupationFilter, themeFilter, sourceFilter].forEach((control) => {
    control?.addEventListener("input", applyFilters);
    control?.addEventListener("change", applyFilters);
  });

  chipButtons.forEach((button) => {
    button.addEventListener("click", () => {
      if (searchInput) {
        searchInput.value = button.dataset.chipQuery || "";
        searchInput.focus();
      }
      if (eraFilter && button.dataset.chipEra !== undefined) {
        eraFilter.value = button.dataset.chipEra || "";
      }
      if (themeFilter && button.dataset.chipTheme !== undefined) {
        themeFilter.value = button.dataset.chipTheme || "";
      }
      if (sourceFilter && button.dataset.chipSource !== undefined) {
        sourceFilter.value = button.dataset.chipSource || "";
      }
      applyFilters();
    });
  });

  document.querySelectorAll<HTMLElement>(".share-card").forEach((share) => {
    share.addEventListener("click", async (event) => {
      event.preventDefault();
      event.stopPropagation();

      const card = share.closest<HTMLAnchorElement>(".figure-card");
      const url = new URL(share.dataset.shareUrl || card?.getAttribute("href") || "/", window.location.origin);
      const title = card?.querySelector("h3")?.textContent?.trim() || "Historical Babes";

      if (navigator.share) {
        await navigator.share({ title, url: url.toString() });
        return;
      }

      await navigator.clipboard?.writeText(url.toString());
      share.textContent = "Copied";
    });
  });
</script>
