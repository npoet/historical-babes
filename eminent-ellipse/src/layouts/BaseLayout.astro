---
import "../styles/globals.css";
import "../styles/layout.css";
import "../styles/grid.css";

interface Props {
  title?: string;
}

const { title = "Historical Figures" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />

    <title>{title}</title>
  </head>

  <body>
    <main class="site-container">
      <slot />
    </main>
  </body>
</html>